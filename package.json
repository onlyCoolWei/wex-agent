{
  "name": "wex-agent",
  "version": "0.1.0",
  "description": "A terminal-based AI coding agent inspired by Claude Code architecture",
  "type": "module",
  "bin": {
    "wex-agent": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup src/cli.ts --format esm --dts --outDir dist",
    "test": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^13.1.0",
    "diff": "^8.0.4",
    "dotenv": "^17.4.1",
    "glob": "^11.0.2",
    "openai": "^6.34.0",
    "ora": "^8.2.0",
    "readline": "^1.3.0",
    "shell-quote": "^1.8.3",
    "strip-ansi": "^7.2.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/diff": "^7.0.2",
    "@types/node": "^22.15.0",
    "@types/shell-quote": "^1.7.5",
    "husky": "^9.1.7",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
